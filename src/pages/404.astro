---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
import { getLangFromPath, getLocalePath, t } from "@/i18n/ui";

const lang = getLangFromPath(Astro.url.pathname);
const i18n = t(lang);
const homeHref = getLocalePath(lang);
---

<Layout title={`${i18n.notFoundPageTitle} | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center">
      <h1 class="text-9xl font-bold text-accent">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="mt-4 text-2xl sm:text-3xl">{i18n.notFoundMessage}</p>
      <LinkButton
        href={homeHref}
        class="my-6 text-lg underline decoration-dashed underline-offset-8"
      >
        {i18n.backToHome}
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>
